{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/frontend/pages/intro/primeira_pagina.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/prisma/**"
    }
  }
}
