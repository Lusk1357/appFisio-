generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          String    @default("PATIENT") // "ADMIN" ou "PATIENT"
  createdAt     DateTime  @default(now())

  patientProfile PatientProfile?
  prescriptions  Prescription[]
  achievements   Achievement[]
}

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  icon        String
  alert       Boolean  @default(false)
  read        Boolean  @default(false)
  timestamp   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model PatientProfile {
  id        String  @id @default(uuid())
  userId    String  @unique
  weight    Float?  // kg
  height    Float?  // cm
  gender    String?
  age       Int?
  telefone  String?
  estado    String?
  cidade    String?
  bairro    String?
  endereco  String?
  cep       String?
  notes     String? // Anotações do fisioterapeuta
  avatar    String? // Nome do arquivo do avatar
  
  user      User    @relation(fields: [userId], references: [id])
}

model Exercise {
  id            String    @id @default(uuid())
  name          String    @unique
  observation   String?   // textos complementares (geral do exercício)
  type          String    // ex: "Fortalecimento", "Alongamento"
  bodyCategory  String?   // Parte do corpo extraída do scraper
  equipments    String?   // Equipamentos necessários extraídos
  videoUrl      String?   // URL principal (opcional agora que temos videos)
  imageUrl      String?   // URL da imagem scrapeada

  videos        ExerciseVideo[]
  prescriptionItems PrescriptionExercise[]
  routineItems      RoutineExercise[]
}

model ExerciseVideo {
  id         String   @id @default(uuid())
  exerciseId String
  name       String   // ex: "Treino A"
  videoUrl   String   // URL do YouTube

  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model Prescription {
  id          String   @id @default(uuid())
  patientId   String   // User (ROLE:PATIENT)
  adminId     String   // User (ROLE:ADMIN)
  assignedDay DateTime // Data alvo do treino
  createdAt   DateTime @default(now())

  patient     User     @relation(fields: [patientId], references: [id])
  exercises   PrescriptionExercise[]
}

model PrescriptionExercise {
  id             String       @id @default(uuid())
  prescriptionId String
  exerciseId     String
  series         String       @default("3x15") // Específico para esta sessão
  observation    String?      // Específico para esta sessão
  restTime       Int          @default(60)     // Tempo de descanso em segundos
  completed      Boolean      @default(false)
  
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  exercise       Exercise     @relation(fields: [exerciseId], references: [id])
}

model Tip {
  id        String   @id @default(uuid())
  title     String
  thumbnail String   // URL da imagem
  duration  String   // Ex: "10 min"
  link      String   // Link do YouTube/externo
  createdAt DateTime @default(now())
}

model RoutineTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  exercises   RoutineExercise[]
}

model RoutineExercise {
  id               String          @id @default(uuid())
  routineId        String
  exerciseId       String
  series           String          @default("3x15")
  observation      String?
  restTime         Int             @default(60)
  
  routine          RoutineTemplate @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise         Exercise        @relation(fields: [exerciseId], references: [id])
}
