generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

generator fieldEncryption {
  provider = "prisma-field-encryption"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  passwordHash   String
  role           String          @default("PATIENT")
  createdAt      DateTime        @default(now())
  achievements   Achievement[]
  patientProfile PatientProfile?
  prescriptions  Prescription[]
}

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  icon        String
  alert       Boolean  @default(false)
  read        Boolean  @default(false)
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model PatientProfile {
  id       String  @id @default(uuid())
  userId   String  @unique
  weight   Float?
  height   Float?
  gender   String?
  age      Int?
  telefone String? /// @encrypted
  estado   String? /// @encrypted
  cidade   String? /// @encrypted
  bairro   String? /// @encrypted
  endereco String? /// @encrypted
  cep      String? /// @encrypted
  notes    String? /// @encrypted
  avatar   String?
  user     User    @relation(fields: [userId], references: [id])
}

model Exercise {
  id                String                 @id @default(uuid())
  name              String                 @unique
  observation       String?
  type              String
  duration          Int                    @default(0)
  videoUrl          String?
  imageUrl          String?
  externalId        String?                @unique
  bodyCategory      String?
  equipments        String?
  howToExecute      String?
  videos            ExerciseVideo[]
  prescriptionItems PrescriptionExercise[]
  routineItems      RoutineExercise[]
}

model ExerciseVideo {
  id         String   @id @default(uuid())
  exerciseId String
  name       String
  videoUrl   String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model Prescription {
  id          String                 @id @default(uuid())
  patientId   String
  adminId     String
  assignedDay DateTime
  createdAt   DateTime               @default(now())
  patient     User                   @relation(fields: [patientId], references: [id])
  exercises   PrescriptionExercise[]
}

model PrescriptionExercise {
  id             String       @id @default(uuid())
  prescriptionId String
  exerciseId     String
  series         String       @default("3x15")
  observation    String?
  restTime       Int          @default(60)
  completed      Boolean      @default(false)
  howToExecute   String?
  exercise       Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
}

model Tip {
  id        String   @id @default(uuid())
  title     String
  thumbnail String
  duration  String
  link      String
  createdAt DateTime @default(now())
}

model RoutineTemplate {
  id          String            @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime          @default(now())
  exercises   RoutineExercise[]
}

model RoutineExercise {
  id           String          @id @default(uuid())
  routineId    String
  exerciseId   String
  series       String          @default("3x15")
  observation  String?
  restTime     Int             @default(60)
  howToExecute String?
  exercise     Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  routine      RoutineTemplate @relation(fields: [routineId], references: [id], onDelete: Cascade)
}
